{
  "rewrites": [
    {
      "source": "/perro/:id",
      "has": [
        {
          "type": "header",
          "key": "User-Agent",
          "value": ".*(facebookexternalhit|Twitterbot|WhatsApp|LinkedInBot|Slackbot|TelegramBot|Discordbot|googlebot|bingbot|applebot).*"
        }
      ],
      "destination": "/api/og-pet?id=:id"
    },
    {
      "source": "/refugio/:slug",
      "has": [
        {
          "type": "header",
          "key": "User-Agent",
          "value": ".*(facebookexternalhit|Twitterbot|WhatsApp|LinkedInBot|Slackbot|TelegramBot|Discordbot|googlebot|bingbot|applebot).*"
        }
      ],
      "destination": "/api/og-shelter?slug=:slug"
    },
    { "source": "/perro/:id", "destination": "/index.html" },
    { "source": "/refugio/:slug", "destination": "/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
